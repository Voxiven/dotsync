# dotsync config — copy to ~/.config/dotsync/config.sh
# All values shown here are defaults; only set what you need to override.
# Normally generated automatically by 'dotsync init'.

# Where the dotsync-managed data lives. This becomes a Syncthing-replicated
# folder; do not rename after initial setup.
DOTSYNC_DATA_DIR="${HOME}/.dotsync-data"

# launchd service name + per-config namespace. Change only if running
# multiple parallel dotsync setups (e.g. work + personal).
DOTSYNC_KC_SERVICE="dev.dotsync.envsync"

# Where source-code projects live on THIS machine. Used to derive Claude
# Code's per-project encoded paths and to expand ${PROJECT_ROOT} in path
# templates. Differs per machine.
# Example: "${HOME}/code", "${HOME}/Workspace", "${HOME}/dev"
DOTSYNC_PROJECT_ROOT="${HOME}"

# Skip session JSONLs above this size (MB). Files this big are usually
# degenerate sessions (large file reads, image captures) where cross-
# machine resume isn't useful.
DOTSYNC_SESSION_MAX_MB=50

# Space-separated project names whose sessions should NOT sync.
# Use for archived projects whose session history isn't worth replicating.
# Example: DOTSYNC_SKIP_PROJECTS="OldProject ArchivedThing"
DOTSYNC_SKIP_PROJECTS=""

# Syncthing folder ID + REST API base. Match Syncthing's defaults; only
# change if running a non-standard Syncthing setup.
SYNCTHING_FOLDER_ID="dotsync-data"
SYNCTHING_API_BASE="http://127.0.0.1:8384"
