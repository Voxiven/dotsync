{
  "name": "claude-code",
  "schema_version": 2,
  "description": "Claude Code: sessions, memory, settings, agents, commands",
  "homepage": "https://docs.claude.com/en/docs/claude-code",
  "iterates_per_project": true,
  "paths": [
    {
      "id": "settings",
      "type": "symlink_file",
      "from": "${HOME}/.claude/settings.json",
      "to": "claude-code/dotfiles/settings.json"
    },
    {
      "id": "claude_md",
      "type": "symlink_file",
      "from": "${HOME}/.claude/CLAUDE.md",
      "to": "claude-code/dotfiles/CLAUDE.md"
    },
    {
      "id": "agents",
      "type": "symlink_directory",
      "from": "${HOME}/.claude/agents",
      "to": "claude-code/agents"
    },
    {
      "id": "commands",
      "type": "symlink_directory",
      "from": "${HOME}/.claude/commands",
      "to": "claude-code/commands"
    },
    {
      "id": "sessions",
      "type": "session_jsonls",
      "from": "${HOME}/.claude/projects/${CC_ENCODED}/",
      "to": "claude-code/sessions/${MACHINE}/${PROJECT}/",
      "include_globs": ["*.jsonl"],
      "exclude_dirs": ["subagents"],
      "max_file_mb": 50,
      "_note": "0.8.0+: per-machine subdirectories. Each peer captures only into its own ${MACHINE}/ subdir, eliminating dual-writer collisions. Deploy walks all peers' subdirs (claude-code/sessions/*/${PROJECT}/) PLUS the legacy 0.7.x location (claude-code/sessions/${PROJECT}/) and line-union merges them into ${HOME}/.claude/projects/${CC_ENCODED}/. No idle gate needed — convergence is structural, not timing-based."
    },
    {
      "id": "memory",
      "type": "shared_per_project_symlink",
      "real": "${HOME}/.claude/projects/${CC_ENCODED}/memory",
      "shared": "claude-code/memory/"
    }
  ]
}
