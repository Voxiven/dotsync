{
  "name": "project-secrets",
  "schema_version": 1,
  "description": "Per-project .env files (so projects run on every machine)",
  "iterates_per_project": true,
  "paths": [
    {
      "id": "env",
      "type": "file",
      "from": "${DOTSYNC_PROJECT_ROOT}/${PROJECT}/.env",
      "to": "project-secrets/${PROJECT}/.env",
      "skip_if_missing": true
    },
    {
      "id": "env_local",
      "type": "file",
      "from": "${DOTSYNC_PROJECT_ROOT}/${PROJECT}/.env.local",
      "to": "project-secrets/${PROJECT}/.env.local",
      "skip_if_missing": true
    }
  ]
}
