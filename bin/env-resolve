#!/usr/bin/env bash
set -uo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"
source "$SCRIPT_DIR/_crypt.sh"

PREFER=""
case "${1:-}" in
  --prefer)
    [[ "${2:-}" =~ ^(local|remote)$ ]] || die "--prefer requires 'local' or 'remote'"
    PREFER="$2"
    ;;
  --help|-h)
    cat <<USAGE
env-resolve [--prefer local|remote]

Resolves all pending sync conflicts under ~/.dotsync-conflicts/.
With --prefer, picks the named side non-interactively.
Without args, opens \$MERGE_TOOL (default: VS Code) for each conflict.
USAGE
    exit 0
    ;;
esac

if ! is_paused; then
  echo "no conflicts pending"
  exit 0
fi

merge_tool="${MERGE_TOOL:-}"
if [[ -z "$merge_tool" ]] && command -v code >/dev/null 2>&1; then
  merge_tool="code --wait --merge"
elif [[ -z "$merge_tool" ]]; then
  merge_tool="opendiff"
fi

resolved_root="$ENV_CONFLICTS_DIR/_resolved"
mkdir -p "$resolved_root"

unlock_repo
cd "$ENV_REPO_ROOT" || die "cannot cd to $ENV_REPO_ROOT"

shopt -s nullglob
for conflict_dir in "$ENV_CONFLICTS_DIR"/*/; do
  conflict_dir="${conflict_dir%/}"
  [[ "$conflict_dir" == "$resolved_root" ]] && continue
  [[ ! -d "$conflict_dir" ]] && continue

  for base_f in "$conflict_dir"/*.base; do
    [[ -f "$base_f" ]] || continue
    name="$(basename "${base_f%.base}")"
    local_f="${base_f%.base}.local"
    remote_f="${base_f%.base}.remote"

    # Find the file in the working tree by name (assumes unique basenames within
    # claude/, secrets/, dotfiles/ — true for current usage).
    target="$(find "$ENV_REPO_ROOT" -type f -name "$name" \
      -not -path '*/.git/*' -not -path '*/conflicts*/*' 2>/dev/null | head -1)"
    if [[ -z "$target" ]]; then
      log_warn "could not locate working-tree target for $name; skipping"
      continue
    fi

    if [[ "$PREFER" == "local" ]]; then
      cp "$local_f" "$target"
    elif [[ "$PREFER" == "remote" ]]; then
      cp "$remote_f" "$target"
    else
      eval "$merge_tool" "$local_f" "$base_f" "$remote_f" "$target"
    fi
    log_info "resolved $name"
  done

  ts="$(basename "$conflict_dir")"
  mv "$conflict_dir" "$resolved_root/$ts"
done
shopt -u nullglob

clear_paused

# Stage and commit the resolved files so the working tree is clean for the
# rebase that follows.
if [[ -n "$(git status --porcelain)" ]]; then
  git add -A
  git commit -m "resolve conflict $(date -u +%Y-%m-%dT%H:%M:%SZ)" --quiet \
    || die "commit of resolved files failed"
fi

# Rebase onto the remote, using -X theirs so any residual file-level
# conflict keeps the content we just committed (our resolved version).
# In rebase, "theirs" = the local commits being replayed (i.e. our resolved
# commit), NOT the upstream — opposite of merge semantics.
git fetch origin "$DOTSYNC_DATA_BRANCH" --quiet || die "git fetch failed after resolve"
if ! git merge-base --is-ancestor HEAD origin/"$DOTSYNC_DATA_BRANCH" 2>/dev/null; then
  if ! git rebase --autostash origin/"$DOTSYNC_DATA_BRANCH" -X theirs --quiet 2>/dev/null; then
    # If even -X theirs fails, surface the error clearly.
    git rebase --abort 2>/dev/null || true
    die "rebase after resolve failed — manual intervention needed"
  fi
fi

git push origin "$DOTSYNC_DATA_BRANCH" --quiet || die "push after resolve failed"
date -u +%Y-%m-%dT%H:%M:%SZ > "$ENV_LASTSYNC_FILE"
log_info "all conflicts resolved; resuming sync"
