#!/usr/bin/env bash
set -uo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"
source "$SCRIPT_DIR/_crypt.sh"

last_sync="never"
[[ -f "$ENV_LASTSYNC_FILE" ]] && last_sync="$(cat "$ENV_LASTSYNC_FILE")"

paused="no"
is_paused && paused="YES"

unlocked="no"
is_repo_unlocked && unlocked="yes"

conflicts="$(find "$ENV_CONFLICTS_DIR" -mindepth 1 -maxdepth 1 -type d \
  -not -name '_resolved' 2>/dev/null | wc -l | tr -d ' ')"

cat <<EOF
Dev-env sync status
-------------------
Repo:           $ENV_REPO_ROOT
Last sync:      $last_sync
Daemon paused:  $paused
Repo unlocked:  $unlocked
Open conflicts: $conflicts
Log:            $ENV_LOG_FILE

EOF

if [[ "$paused" == "YES" ]]; then
  echo "⚠  Sync is paused. Run env-resolve to clear conflicts."
fi
