#!/usr/bin/env bash
# dotsync pair — dispatcher. Routes based on $DOTSYNC_ENGINE in the
# current config (or override via --engine).
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source config to learn current engine.
DOTSYNC_CONFIG="${DOTSYNC_CONFIG:-${HOME}/.config/dotsync/config.sh}"
[[ -f "$DOTSYNC_CONFIG" ]] && source "$DOTSYNC_CONFIG" 2>/dev/null

ENGINE="${DOTSYNC_ENGINE:-}"
ARGS=()
HELP_REQUESTED=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --engine) ENGINE="$2"; shift 2 ;;
    --engine=*) ENGINE="${1#*=}"; shift ;;
    -h|--help) HELP_REQUESTED=true; shift ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

if $HELP_REQUESTED && [[ -z "$ENGINE" ]]; then
  cat <<EOF
dotsync pair — emit a one-time pairing code for adding a second machine.

Usage: dotsync pair [--engine <git|syncthing>]

Engine is auto-detected from your config. Override with --engine.

Per-engine help:
  dotsync pair --engine syncthing --help
  dotsync pair --engine git --help
EOF
  exit 0
fi

ENGINE="${ENGINE:-syncthing}"
$HELP_REQUESTED && ARGS+=("--help")

case "$ENGINE" in
  syncthing) exec "$SCRIPT_DIR/dotsync-pair-syncthing" ${ARGS[@]+"${ARGS[@]}"} ;;
  git)       exec "$SCRIPT_DIR/dotsync-pair-git" ${ARGS[@]+"${ARGS[@]}"} ;;
  *) echo "✗ unknown engine: $ENGINE" >&2; exit 1 ;;
esac
