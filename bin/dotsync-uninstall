#!/usr/bin/env bash
# dotsync-uninstall — tear down a dotsync setup on this machine.
#
# Reads $DOTSYNC_CONFIG (or env-overridden values) to find what to remove.
# Targets exactly one setup at a time, so you can have multiple dotsync
# setups (e.g. work + personal) and uninstall them independently by
# sourcing the right config first.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_common.sh"

KEEP_DATA=false
KEEP_CONFIG=false
FORCE=false

usage() {
  cat <<EOF
dotsync uninstall — fully tear down a dotsync setup on this machine.

Usage: dotsync uninstall [options]

Options:
  --keep-data    Don't delete \$DOTSYNC_DATA_DIR.
  --keep-config  Don't delete \$DOTSYNC_CONFIG.
  --force        Skip the confirmation prompt.

What it removes:
  - launchd plist:  \$HOME/Library/LaunchAgents/\$DOTSYNC_KC_SERVICE.plist
  - per-machine state dir: \$DOTSYNC_STATE_DIR (default ~/.dotsync-state)
  - data dir:       \$DOTSYNC_DATA_DIR
  - config file:    \$DOTSYNC_CONFIG

Does NOT touch:
  - Syncthing's installation or its other folders (use 'brew services
    stop syncthing' separately if you don't want Syncthing at all)
  - ~/.claude/projects/* — Claude Code's session files
  - The dotsync tool itself

To uninstall a specific setup when you have multiple:
  DOTSYNC_CONFIG=~/.config/dotsync/config-other.sh dotsync uninstall
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-data)   KEEP_DATA=true; shift ;;
    --keep-config) KEEP_CONFIG=true; shift ;;
    --force)       FORCE=true; shift ;;
    -h|--help)     usage; exit 0 ;;
    *)             echo "unknown flag: $1" >&2; usage; exit 1 ;;
  esac
done

LABEL="$DOTSYNC_KC_SERVICE"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"

step() { printf '\n→ %s\n' "$*"; }
say()  { printf '  %s\n' "$*"; }
note() { printf '    (%s)\n' "$*"; }

# ── Plan ────────────────────────────────────────────────────────────
cat <<EOF

About to uninstall this dotsync setup:

  Service:        $DOTSYNC_KC_SERVICE
  Config:         $DOTSYNC_CONFIG $($KEEP_CONFIG && echo "(KEEPING)")
  Data dir:       $DOTSYNC_DATA_DIR $($KEEP_DATA && echo "(KEEPING)")
  State dir:      $DOTSYNC_STATE_DIR
  launchd plist:  $PLIST

This will NOT touch:
  - Syncthing itself (its own folders, its brew service)
  - ~/.claude/projects/* (CC session files)
  - Other dotsync setups on this machine

EOF

if ! $FORCE; then
  read -rp "Proceed? Type 'yes' to confirm: " ans
  [[ "$ans" == "yes" ]] || { echo "aborted"; exit 1; }
fi

# ── Execute ─────────────────────────────────────────────────────────
step "launchd agent"
if [[ -f "$PLIST" ]]; then
  launchctl unload "$PLIST" 2>/dev/null && say "unloaded" || note "was not loaded"
  rm -f "$PLIST" && say "removed plist"
else
  note "no plist at $PLIST"
fi

step "Per-machine state dir"
if [[ -d "$DOTSYNC_STATE_DIR" ]]; then
  rm -rf "$DOTSYNC_STATE_DIR" && say "removed $DOTSYNC_STATE_DIR"
else
  note "$DOTSYNC_STATE_DIR does not exist"
fi

step "Data dir"
if $KEEP_DATA; then
  note "keeping per --keep-data"
elif [[ -d "$DOTSYNC_DATA_DIR" ]]; then
  rm -rf "$DOTSYNC_DATA_DIR" && say "removed $DOTSYNC_DATA_DIR"
else
  note "$DOTSYNC_DATA_DIR does not exist"
fi

step "Config file"
if $KEEP_CONFIG; then
  note "keeping per --keep-config"
elif [[ -f "$DOTSYNC_CONFIG" ]]; then
  rm -f "$DOTSYNC_CONFIG" && say "removed $DOTSYNC_CONFIG"
else
  note "$DOTSYNC_CONFIG does not exist"
fi

cat <<EOF

✅ uninstall complete.

Other dotsync setups (if any) on this machine are untouched.

To remove Syncthing too:
  brew services stop syncthing
  brew uninstall syncthing
EOF
