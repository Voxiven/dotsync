# ── HTTP handler ──────────────────────────────────────────────────────


def _bin(name: str) -> Path:
    return tool_dir() / "bin" / name


def _run_action(name: str, args: list[str]) -> tuple[bool, str]:
    """Run a bin/<name> subcommand. Returns (ok, message)."""
    path = _bin(name)
    if not path.exists():
        return False, f"{name}: command not found"
    try:
        proc = subprocess.run(
            [str(path), *args], capture_output=True, text=True, timeout=60
        )
    except Exception as e:
        return False, f"{name}: {e}"
    if proc.returncode != 0:
        msg = (proc.stderr or proc.stdout or "").strip().splitlines()
        return False, msg[-1] if msg else f"{name} exited {proc.returncode}"
    out = (proc.stdout or "").strip().splitlines()
    return True, out[-1] if out else f"{name}: ok"


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        sys.stderr.write(f"[{self.log_date_time_string()}] {format % args}\n")

    def _serve(
        self,
        code: int,
        body: bytes,
        content_type: str = "text/html; charset=utf-8",
    ) -> None:
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _serve_json(self, code: int, payload: dict) -> None:
        self._serve(code, json.dumps(payload).encode(), "application/json")

    # Auth — loopback bypass + token check for everything else.
    def _is_loopback(self) -> bool:
        ip = self.client_address[0]
        return ip == "::1" or ip.startswith("127.")

    def _present_token(self) -> str:
        qs = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
        token = qs.get("token", [""])[0]
        if not token:
            token = self.headers.get("X-Dotsync-Token", "")
        return token

    def _authed(self) -> bool:
        if not UI_TOKEN:
            return True  # no token configured (shouldn't happen in main path)
        if self._is_loopback():
            return True
        token = self._present_token()
        return bool(token) and secrets.compare_digest(token, UI_TOKEN)

    def do_GET(self) -> None:  # noqa: N802
        path = urllib.parse.urlparse(self.path).path
        if path == "/healthz":
            self._serve_json(200, {"ok": True, "version": VERSION})
            return
        if not self._authed():
            if path in ("/", ""):
                self._serve(200, LOGIN_PAGE.encode())
            else:
                self._serve_json(401, {"error": "unauthorized"})
            return
        if path == "/api/status":
            self._serve_json(200, gather_status(load_config()))
        elif path in ("/", ""):
            self._serve(200, PAGE.encode())
        else:
            self._serve(404, b"not found", "text/plain")

    def do_POST(self) -> None:  # noqa: N802
        path = urllib.parse.urlparse(self.path).path
        if not self._authed():
            self._serve_json(401, {"error": "unauthorized"})
            return
        if path == "/api/sync":
            ok, msg = _run_action("env-sync", [])
        elif path == "/api/pause":
            ok, msg = _run_action("dotsync-pause", [])
        elif path == "/api/resume":
            ok, msg = _run_action("dotsync-resume", [])
        elif path == "/api/clean-conflicts":
            ok, msg = _run_action(
                "dotsync-clean-conflicts", ["--apply", "--merge"]
            )
        else:
            self._serve_json(404, {"error": "unknown action"})
            return
        self._serve_json(200 if ok else 500, {"ok": ok, "message": msg})


# ── Background launchd agent (used by --install / --uninstall) ────────


UI_LABEL = "dev.dotsync.ui"


def _ui_plist_path() -> Path:
    return Path.home() / "Library" / "LaunchAgents" / f"{UI_LABEL}.plist"


def _stable_dotsync_path() -> str:
    """Path to the dotsync dispatcher that survives 'brew upgrade'.

    Prefer a PATH-discoverable 'dotsync' (Homebrew creates a stable
    /opt/homebrew/bin/dotsync symlink that re-points at the new Cellar
    after upgrade — so the plist keeps working). Fall back to a sibling
    of this script for dev installs (running ./bin/dotsync-ui directly).
    """
    p = shutil.which("dotsync")
    if p:
        return p
    return str(tool_dir() / "bin" / "dotsync")


def install_ui_agent() -> int:
    """Install + load the launchd agent that keeps the dashboard up.

    Idempotent: re-running replaces the plist and reloads. Returns 0 on
    success, non-zero on failure.
    """
    template = tool_dir() / "launchd" / "dev.dotsync.ui.plist.template"
    if not template.exists():
        print(
            f"error: template missing at {template}\n"
            "       (likely a corrupted install — try 'brew reinstall dotsync')",
            file=sys.stderr,
        )
        return 1

    cfg_path = os.environ.get(
        "DOTSYNC_CONFIG", str(Path.home() / ".config" / "dotsync" / "config.sh")
    )
    bin_path = _stable_dotsync_path()

    rendered = template.read_text()
    rendered = rendered.replace("__LABEL__", UI_LABEL)
    rendered = rendered.replace("__DOTSYNC_BIN__", bin_path)
    rendered = rendered.replace("__HOME__", str(Path.home()))
    rendered = rendered.replace("__CONFIG__", cfg_path)

    plist = _ui_plist_path()
    plist.parent.mkdir(parents=True, exist_ok=True)
    plist.write_text(rendered)

    # Validate before loading so a typo doesn't leave us with a broken plist.
    lint = subprocess.run(
        ["plutil", "-lint", str(plist)], capture_output=True, text=True
    )
    if lint.returncode != 0:
        print(f"error: plist failed plutil -lint:\n{lint.stdout}{lint.stderr}",
              file=sys.stderr)
        return 1

    # Unload any prior instance so changes take effect; ignore errors
    # (likely not loaded yet on first install).
    subprocess.run(
        ["launchctl", "unload", str(plist)], capture_output=True
    )
    load = subprocess.run(
        ["launchctl", "load", "-w", str(plist)], capture_output=True, text=True
    )
    if load.returncode != 0:
        print(f"error: launchctl load failed:\n{load.stderr}", file=sys.stderr)
        return 1

    print(f"installed: {plist}")
    print(f"  runs:    {bin_path} ui --background --no-open")
    print(f"  visit:   http://127.0.0.1:7878/")
    print(f"  logs:    ~/Library/Logs/dotsync-ui.{{out,err}}.log")
    print()
    print("Auto-starts at login and on crash. To stop:")
    print(f"  dotsync ui --uninstall")
    return 0


def uninstall_ui_agent() -> int:
    """Unload + remove the launchd agent. Idempotent."""
    plist = _ui_plist_path()
    if not plist.exists():
        print("no UI agent installed.")
        return 0
    subprocess.run(
        ["launchctl", "unload", str(plist)], capture_output=True
    )
    plist.unlink()
    print(f"removed: {plist}")
    return 0


# ── Cloudflared quick tunnel (used by --share) ────────────────────────


_TRYCF_RE = re.compile(r"https://[a-z0-9-]+\.trycloudflare\.com")


def _publish_mdns(port: int) -> subprocess.Popen | None:
    """Register dotsync.local → 127.0.0.1 via macOS mDNS (Bonjour).

    Spawns `dns-sd -P` in the background. The registration lives as long
    as the process does, so launchd's KeepAlive keeps dotsync.local
    alive across crashes/restarts.

    `dns-sd -P` arguments:
      <name>     service instance name (visible to network browsers)
      <type>     service type — _http._tcp for a web service
      <domain>   "local" — the mDNS multicast domain
      <port>     port the service is on
      <host>     hostname to register an A record for
      <addr>     IPv4 address that hostname resolves to
    """
    if not shutil.which("dns-sd"):
        return None
    try:
        return subprocess.Popen(
            [
                "dns-sd", "-P",
                "dotsync", "_http._tcp", "local",
                str(port),
                "dotsync.local", "127.0.0.1",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        return None


def start_cloudflared(local_url: str, token: str) -> subprocess.Popen | None:
    """Spawn `cloudflared tunnel --url <local>` and print the public URL.

    Returns the Popen handle, or None if cloudflared is unavailable.
    The public URL is parsed from cloudflared's stderr stream (where it
    logs the tunnel hostname); we print it once to the user with the
    auth token appended so they can open it directly.
    """
    if not shutil.which("cloudflared"):
        print(
            "⚠  cloudflared not found.\n"
            "   Install with:  brew install cloudflared\n"
            "   --share needs it to expose the dashboard via a "
            "Cloudflare quick tunnel.",
            file=sys.stderr,
        )
        return None

    print("Starting cloudflared quick tunnel…")
    proc = subprocess.Popen(
        ["cloudflared", "tunnel", "--no-autoupdate", "--url", local_url],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )

    printed = threading.Event()

    def reader():
        assert proc.stdout is not None
        for line in proc.stdout:
            if not printed.is_set():
                m = _TRYCF_RE.search(line)
                if m:
                    public = m.group(0)
                    print()
                    print(f"  Public URL:  {public}/?token={token}")
                    print()
                    print(
                        "  Open on any device. Ctrl-C here tears the tunnel "
                        "down."
                    )
                    print(
                        "  Note: quick-tunnel hostnames are ephemeral — "
                        "expect a new URL on next --share."
                    )
                    print()
                    printed.set()
            # Surface cloudflared errors so we don't hide a broken tunnel.
            if "ERR" in line or "FATAL" in line or "level=err" in line.lower():
                sys.stderr.write(f"[cloudflared] {line}")

    threading.Thread(target=reader, daemon=True).start()
    return proc


# ── Entry ─────────────────────────────────────────────────────────────


def main() -> None:
    parser = argparse.ArgumentParser(description="dotsync local status dashboard")
    parser.add_argument("--port", type=int, default=7878)
    parser.add_argument("--bind", default="127.0.0.1")
    parser.add_argument(
        "--no-open", action="store_true", help="Don't open the browser automatically"
    )
    parser.add_argument(
        "--background", action="store_true", help="Run silently (for launchd)"
    )
    parser.add_argument(
        "--share",
        action="store_true",
        help="Expose dashboard via cloudflared quick tunnel (token-protected)",
    )
    parser.add_argument(
        "--install",
        action="store_true",
        help="Install launchd agent so the dashboard runs in the background",
    )
    parser.add_argument(
        "--uninstall",
        action="store_true",
        help="Remove the launchd agent",
    )
    args = parser.parse_args()

    # Install/uninstall short-circuit: don't start a server, just manage the
    # launchd plist and exit.
    if args.install:
        sys.exit(install_ui_agent())
    if args.uninstall:
        sys.exit(uninstall_ui_agent())

    # Line-buffer stdout so users running with output redirected (launchd,
    # piped to a file) see "Public URL: ..." immediately when --share runs,
    # not whenever the block buffer happens to flush.
    try:
        sys.stdout.reconfigure(line_buffering=True)
    except Exception:
        pass

    cfg = load_config()
    state_dir = Path(cfg["DOTSYNC_STATE_DIR"])
    global UI_TOKEN
    UI_TOKEN = load_or_create_token(state_dir)

    url = f"http://{args.bind}:{args.port}/"
    if not args.background:
        print(f"Dashboard at {url}")
        if args.bind not in ("127.0.0.1", "::1", "localhost"):
            print(
                f"  Token (paste at /?token=…):  "
                f"{UI_TOKEN[:8]}…{UI_TOKEN[-4:]}  "
                f"(full: {state_dir}/ui-token)"
            )
        print("Ctrl-C to stop.")

    cf_proc: subprocess.Popen | None = None
    mdns_proc: subprocess.Popen | None = None

    def cleanup() -> None:
        for proc in (cf_proc, mdns_proc):
            if proc is None or proc.poll() is not None:
                continue
            try:
                proc.terminate()
                proc.wait(timeout=2)
            except (subprocess.TimeoutExpired, OSError):
                try:
                    proc.kill()
                except OSError:
                    pass

    # Sibling subprocesses — they don't inherit signals sent to us.
    # Catch SIGTERM (the default `kill` signal), run cleanup, then exit.
    # Without this the children outlive the parent.
    def _on_signal(_signum, _frame):
        cleanup()
        os._exit(0)

    signal.signal(signal.SIGTERM, _on_signal)

    # Publish dotsync.local via macOS mDNS so the dashboard is reachable
    # at http://dotsync.local:<port>/ in any browser, no /etc/hosts edit
    # or sudo. dns-sd -P registers an mDNS service AND a hostname A
    # record pointing at 127.0.0.1 — each machine resolves dotsync.local
    # to its own loopback, so multi-machine setups don't cross over.
    # Silent fallback if dns-sd isn't on PATH (very old macOS, or Linux
    # support down the line).
    mdns_proc = _publish_mdns(args.port)
    if not args.background and mdns_proc is not None:
        print(f"  also at:  http://dotsync.local:{args.port}/")

    if args.share:
        # Quick tunnel always points at 127.0.0.1; the server itself can
        # stay loopback-bound — cloudflared is the bridge.
        cf_proc = start_cloudflared(f"http://127.0.0.1:{args.port}", UI_TOKEN)

    if not args.no_open and not args.background and not args.share:
        try:
            webbrowser.open(url)
        except Exception:
            pass

    socketserver.TCPServer.allow_reuse_address = True
    try:
        with socketserver.TCPServer((args.bind, args.port), Handler) as httpd:
            try:
                httpd.serve_forever()
            except KeyboardInterrupt:
                if not args.background:
                    print("\nShutting down.")
    finally:
        cleanup()


if __name__ == "__main__":
    main()
