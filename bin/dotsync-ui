#!/usr/bin/env python3
"""
dotsync-ui — local status dashboard at http://127.0.0.1:7878

Reads existing state files (no new state introduced):
  - $DOTSYNC_DATA_DIR/.last-sync
  - $DOTSYNC_DATA_DIR/.sync-paused
  - $HOME/.dotsync-conflicts/<ts>/
  - $HOME/Library/Logs/dotsync.log
  - $DOTSYNC_DATA_DIR/registry/*.json
  - profiles/*.json from the tool dir
  - git log on the data repo for peer activity

POST endpoints invoke other dotsync subcommands via subprocess:
  - /api/sync   → dotsync sync
  - /api/pause  → dotsync pause   (TODO once implemented)
  - /api/resume → dotsync resume  (TODO once implemented)
"""
from __future__ import annotations

import argparse
import datetime as dt
import http.server
import json
import os
import re
import shlex
import socketserver
import subprocess
import sys
import urllib.parse
import webbrowser
from pathlib import Path

# ── Configuration loading ─────────────────────────────────────────────


def load_config() -> dict:
    """Source ~/.config/dotsync/config.sh and capture variables."""
    cfg = {
        "DOTSYNC_DATA_DIR": os.environ.get(
            "DOTSYNC_DATA_DIR", str(Path.home() / ".dotsync-data")
        ),
        "DOTSYNC_KC_SERVICE": os.environ.get(
            "DOTSYNC_KC_SERVICE", "dev.dotsync.envsync"
        ),
        "DOTSYNC_PROJECT_ROOT": os.environ.get(
            "DOTSYNC_PROJECT_ROOT", str(Path.home())
        ),
        "DOTSYNC_ENGINE": os.environ.get("DOTSYNC_ENGINE", "syncthing"),
        "SYNCTHING_FOLDER_ID": os.environ.get("SYNCTHING_FOLDER_ID", "dotsync-data"),
        "SYNCTHING_API_BASE": os.environ.get(
            "SYNCTHING_API_BASE", "http://127.0.0.1:8384"
        ),
    }
    cfg_file = Path.home() / ".config" / "dotsync" / "config.sh"
    if cfg_file.exists():
        for line in cfg_file.read_text().splitlines():
            m = re.match(r'^([A-Z_][A-Z0-9_]*)="?([^"]*)"?$', line.strip())
            if m:
                cfg[m.group(1)] = m.group(2)
    return cfg


def tool_dir() -> Path:
    return Path(__file__).resolve().parent.parent


# ── Syncthing REST API helpers ───────────────────────────────────────


def _st_api_key(cfg: dict) -> str | None:
    """Read the cached Syncthing API key, or extract from config.xml."""
    cached = Path.home() / "Library/Application Support/Syncthing/apikey"
    if cached.exists():
        return cached.read_text().strip()
    cfg_xml = Path.home() / "Library/Application Support/Syncthing/config.xml"
    if not cfg_xml.exists():
        return None
    m = re.search(r"<apikey>([^<]+)</apikey>", cfg_xml.read_text())
    return m.group(1) if m else None


def _st_call(cfg: dict, path: str) -> dict | list | None:
    """GET a Syncthing REST endpoint; return parsed JSON or None on error."""
    api_key = _st_api_key(cfg)
    if not api_key:
        return None
    import urllib.request

    url = cfg["SYNCTHING_API_BASE"].rstrip("/") + path
    req = urllib.request.Request(url, headers={"X-API-Key": api_key})
    try:
        with urllib.request.urlopen(req, timeout=2) as resp:
            return json.load(resp)
    except Exception:
        return None


def gather_syncthing_status(cfg: dict) -> dict:
    """Return engine-specific status: folder state, peers, conflicts."""
    folder_id = cfg["SYNCTHING_FOLDER_ID"]

    # Daemon up?
    sys_status = _st_call(cfg, "/rest/system/status")
    if not sys_status:
        return {"running": False}

    folder_status = _st_call(cfg, f"/rest/db/status?folder={folder_id}") or {}
    connections = _st_call(cfg, "/rest/system/connections") or {}
    devices = _st_call(cfg, "/rest/config/devices") or []

    # Build per-peer view: {device_name: {connected, address, last_seen}}.
    my_id = sys_status.get("myID", "")
    device_names = {d["deviceID"]: d.get("name") or d["deviceID"][:7] for d in devices}
    conn_map = (connections.get("connections") or {})
    peers: dict[str, dict] = {}
    for dev_id, name in device_names.items():
        if dev_id == my_id:
            continue
        c = conn_map.get(dev_id, {})
        peers[name] = {
            "device_id": dev_id,
            "connected": c.get("connected", False),
            "address": c.get("address", ""),
            "in_bytes": c.get("inBytesTotal", 0),
            "out_bytes": c.get("outBytesTotal", 0),
        }

    # Find sync-conflict files in the data dir.
    data_dir = Path(cfg["DOTSYNC_DATA_DIR"])
    conflicts: list[str] = []
    if data_dir.exists():
        for p in data_dir.rglob("*.sync-conflict-*"):
            if p.is_file():
                conflicts.append(str(p.relative_to(data_dir)))

    return {
        "running": True,
        "my_id": my_id,
        "version": sys_status.get("version", ""),
        "folder_id": folder_id,
        "folder_state": folder_status.get("state", "unknown"),
        "folder_global_files": folder_status.get("globalFiles", 0),
        "folder_local_files": folder_status.get("localFiles", 0),
        "folder_in_sync_pct": folder_status.get("inSyncBytes", 0) /
            max(folder_status.get("globalBytes", 1), 1) * 100,
        "peers": peers,
        "conflicts": conflicts,
    }


# ── Status gathering ──────────────────────────────────────────────────


def gather_status(cfg: dict) -> dict:
    data_dir = Path(cfg["DOTSYNC_DATA_DIR"])
    home = Path.home()

    # Last sync timestamp.
    last_sync = ""
    last_sync_file = data_dir / ".last-sync"
    if last_sync_file.exists():
        last_sync = last_sync_file.read_text().strip()

    # Paused flag.
    paused = (data_dir / ".sync-paused").exists()

    # Conflicts.
    conflicts_dir = home / ".dotsync-conflicts"
    conflicts: list[dict] = []
    if conflicts_dir.exists():
        for p in sorted(conflicts_dir.iterdir()):
            if p.is_dir() and p.name != "_resolved":
                files = sorted(f.name for f in p.iterdir() if f.is_file())
                conflicts.append({"id": p.name, "files": files})

    # Daemon state (launchctl).
    daemon = "unknown"
    try:
        out = subprocess.run(
            ["launchctl", "list"], capture_output=True, text=True, timeout=2
        ).stdout
        daemon = "loaded" if cfg["DOTSYNC_KC_SERVICE"] in out else "not-loaded"
    except Exception:
        pass

    # Git branch.
    branch = "?"
    if (data_dir / ".git").exists():
        try:
            branch = subprocess.run(
                ["git", "-C", str(data_dir), "rev-parse", "--abbrev-ref", "HEAD"],
                capture_output=True, text=True, timeout=2,
            ).stdout.strip()
        except Exception:
            pass

    # Peers (last commit per author/hostname over last 50 commits).
    peers: dict[str, str] = {}
    if (data_dir / ".git").exists():
        try:
            log = subprocess.run(
                ["git", "-C", str(data_dir), "log", "-50", "--format=%an|%ai|%s"],
                capture_output=True, text=True, timeout=3,
            ).stdout
            for line in log.splitlines():
                parts = line.split("|", 2)
                if len(parts) < 3:
                    continue
                author, when, subject = parts
                # Pull hostname out of "auto-sync <host> <iso-ts>" subjects.
                m = re.match(r"^auto-sync\s+(\S+)\s+", subject)
                key = m.group(1) if m else author
                if key not in peers:
                    peers[key] = when
        except Exception:
            pass

    # Profiles.
    profiles: list[dict] = []
    enabled = set()
    enabled_file = data_dir / "registry" / "enabled-profiles.json"
    if enabled_file.exists():
        try:
            enabled = set(json.loads(enabled_file.read_text()).get("profiles", []))
        except Exception:
            pass
    profiles_dir = tool_dir() / "profiles"
    if profiles_dir.exists():
        for p in sorted(profiles_dir.glob("*.json")):
            try:
                d = json.loads(p.read_text())
                profiles.append({
                    "name": d.get("name", p.stem),
                    "description": d.get("description", ""),
                    "experimental": d.get("experimental", False),
                    "enabled": d.get("name") in enabled,
                    "paths": len(d.get("paths", [])),
                })
            except Exception:
                pass

    # Tracked secrets (legacy registry).
    secrets: list[dict] = []
    secrets_file = data_dir / "registry" / "secrets.json"
    if secrets_file.exists():
        try:
            secrets = json.loads(secrets_file.read_text()).get("secrets", [])
        except Exception:
            pass

    # Project list.
    projects: list[str] = []
    projects_file = data_dir / "registry" / "projects.json"
    if projects_file.exists():
        try:
            d = json.loads(projects_file.read_text())
            projects = [p.get("name", "?") for p in d.get("projects", [])]
        except Exception:
            pass

    # Recent log lines.
    log_file = home / "Library" / "Logs" / "dotsync.log"
    log_tail: list[str] = []
    if log_file.exists():
        try:
            with log_file.open() as f:
                log_tail = f.readlines()[-30:]
        except Exception:
            pass

    engine = cfg.get("DOTSYNC_ENGINE", "git")
    syncthing: dict | None = None
    if engine == "syncthing":
        syncthing = gather_syncthing_status(cfg)
        # Engine-specific surfaces override the git-derived ones:
        # peers come from Syncthing connections; conflicts come from
        # the *.sync-conflict-* sidecar scan.
        if syncthing.get("running"):
            peers = {
                name: ("connected" if p["connected"] else "offline")
                for name, p in syncthing["peers"].items()
            }
            conflicts = [
                {"id": Path(c).parent.name or "<root>", "files": [Path(c).name]}
                for c in syncthing.get("conflicts", [])
            ]
            branch = "syncthing:" + syncthing.get("folder_state", "?")

    return {
        "engine": engine,
        "service": cfg["DOTSYNC_KC_SERVICE"],
        "data_dir": str(data_dir),
        "branch": branch,
        "last_sync": last_sync,
        "paused": paused,
        "conflicts": conflicts,
        "daemon": daemon,
        "peers": peers,
        "profiles": profiles,
        "secrets": secrets,
        "projects": projects,
        "log_tail": [l.rstrip() for l in log_tail],
        "syncthing": syncthing,
        "now": dt.datetime.utcnow().isoformat() + "Z",
    }


# ── HTML rendering ────────────────────────────────────────────────────


HTML_TEMPLATE = r"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta http-equiv="refresh" content="10">
<title>dotsync — {service}</title>
<style>
  :root {{
    --bg: #0d1117;
