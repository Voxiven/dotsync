#!/usr/bin/env python3
"""dotsync-ui — local status dashboard at http://127.0.0.1:7878.

Reads on-disk state and proxies actions to the dotsync subcommands. The
page is a static HTML/JS shell; everything dynamic flows through
GET /api/status (JSON) and POST /api/{sync,pause,resume,clean-conflicts}.
"""
from __future__ import annotations

import argparse
import datetime as dt
import http.server
import json
import os
import re
import secrets
import shutil
import signal
import socketserver
import subprocess
import sys
import threading
import urllib.parse
import webbrowser
from pathlib import Path

# Read VERSION from bin/dotsync (single source of truth) so a release
# bump only needs to touch the dispatcher.
def _read_version() -> str:
    here = Path(__file__).resolve().parent
    try:
        for line in (here / "dotsync").read_text().splitlines():
            if line.startswith("VERSION="):
                return line.split("=", 1)[1].strip().strip('"').strip("'")
    except OSError:
        pass
    return "unknown"


VERSION = _read_version()

# Token for non-loopback access. Empty = auth disabled (loopback-only mode).
# Populated by main() on startup; checked by Handler.
UI_TOKEN: str = ""


def load_or_create_token(state_dir: Path) -> str:
    """Load ~/.dotsync-state/ui-token; create on first call. Mode 0600."""
    state_dir.mkdir(parents=True, exist_ok=True)
    token_file = state_dir / "ui-token"
    if token_file.exists():
        tok = token_file.read_text().strip()
        if tok:
            return tok
    tok = secrets.token_hex(32)  # 256 bits, hex-encoded
    token_file.write_text(tok)
    try:
        os.chmod(token_file, 0o600)
    except OSError:
        pass
    return tok


# ── Configuration loading ─────────────────────────────────────────────


def load_config() -> dict:
    """Source ~/.config/dotsync/config.sh and capture variables."""
    cfg = {
        "DOTSYNC_DATA_DIR": os.environ.get(
            "DOTSYNC_DATA_DIR", str(Path.home() / ".dotsync-data")
        ),
        "DOTSYNC_STATE_DIR": os.environ.get(
            "DOTSYNC_STATE_DIR", str(Path.home() / ".dotsync-state")
        ),
        "DOTSYNC_KC_SERVICE": os.environ.get(
            "DOTSYNC_KC_SERVICE", "dev.dotsync.envsync"
        ),
        "DOTSYNC_PROJECT_ROOT": os.environ.get(
            "DOTSYNC_PROJECT_ROOT", str(Path.home())
        ),
        "SYNCTHING_FOLDER_ID": os.environ.get("SYNCTHING_FOLDER_ID", "dotsync-data"),
        "SYNCTHING_API_BASE": os.environ.get(
            "SYNCTHING_API_BASE", "http://127.0.0.1:8384"
        ),
    }
    cfg_file = Path.home() / ".config" / "dotsync" / "config.sh"
    if cfg_file.exists():
        for line in cfg_file.read_text().splitlines():
            m = re.match(r'^([A-Z_][A-Z0-9_]*)="?([^"]*)"?$', line.strip())
            if m:
                cfg[m.group(1)] = m.group(2)
    return cfg


def tool_dir() -> Path:
    return Path(__file__).resolve().parent.parent


# ── Syncthing REST API helpers ───────────────────────────────────────


def _st_api_key() -> str | None:
    """Read the cached Syncthing API key, or extract from config.xml."""
    cached = Path.home() / "Library/Application Support/Syncthing/apikey"
    if cached.exists():
        return cached.read_text().strip()
    cfg_xml = Path.home() / "Library/Application Support/Syncthing/config.xml"
    if not cfg_xml.exists():
        return None
    m = re.search(r"<apikey>([^<]+)</apikey>", cfg_xml.read_text())
    return m.group(1) if m else None


def _st_call(cfg: dict, path: str) -> dict | list | None:
    api_key = _st_api_key()
    if not api_key:
        return None
    import urllib.request

    url = cfg["SYNCTHING_API_BASE"].rstrip("/") + path
    req = urllib.request.Request(url, headers={"X-API-Key": api_key})
    try:
        with urllib.request.urlopen(req, timeout=2) as resp:
            return json.load(resp)
    except Exception:
        return None


def _classify_connection(c: dict) -> str:
    """Map a Syncthing connection record to one of:
       lan      — direct, peer is on the same broadcast LAN
       wan      — direct, peer is on a different network (NAT-punched)
       relay    — going through a Syncthing public relay (encrypted)
       offline  — no current connection

    The Syncthing /rest/system/connections endpoint returns per-peer:
      connected: bool
      type: "tcp-server" | "tcp-client" | "quic-server" | "quic-client" |
            "relay-server" | "relay-client" | ...
      isLocal: bool (peer's address is RFC1918 / link-local)
    Direct vs relayed is in `type`; LAN vs WAN is in `isLocal`.
    """
    if not c.get("connected"):
        return "offline"
    conn_type = (c.get("type") or "").lower()
    if "relay" in conn_type:
        return "relay"
    if c.get("isLocal"):
        return "lan"
    return "wan"


def gather_syncthing(cfg: dict) -> dict:
    sys_status = _st_call(cfg, "/rest/system/status")
    if not sys_status:
        return {"running": False}

    folder_id = cfg["SYNCTHING_FOLDER_ID"]
    version_data = _st_call(cfg, "/rest/system/version") or {}
    folder_status = _st_call(cfg, f"/rest/db/status?folder={folder_id}") or {}
    connections = _st_call(cfg, "/rest/system/connections") or {}
    devices = _st_call(cfg, "/rest/config/devices") or []

    my_id = sys_status.get("myID", "")
    device_names = {
        d["deviceID"]: d.get("name") or d["deviceID"][:7] for d in devices
    }
    conn_map = (connections.get("connections") or {})
    peers: list[dict] = []
    for dev_id, name in device_names.items():
        if dev_id == my_id:
            continue
        c = conn_map.get(dev_id, {})
        peers.append({
            "name": name,
            "device_id": dev_id,
            "device_id_short": dev_id.split("-")[0] if dev_id else "",
            "connected": c.get("connected", False),
            "address": c.get("address", ""),
            "in_bytes": c.get("inBytesTotal", 0),
            "out_bytes": c.get("outBytesTotal", 0),
            "connection_kind": _classify_connection(c),
        })

    global_bytes = max(folder_status.get("globalBytes", 1) or 1, 1)
    in_sync_pct = folder_status.get("inSyncBytes", 0) / global_bytes * 100

    return {
        "running": True,
        "my_id": my_id,
        "version": version_data.get("version", ""),
        "folder_id": folder_id,
        "folder_state": folder_status.get("state", "unknown"),
        "global_files": folder_status.get("globalFiles", 0),
        "local_files": folder_status.get("localFiles", 0),
        "in_sync_pct": in_sync_pct,
        "peers": peers,
    }


# ── Conflict scanning ────────────────────────────────────────────────


# Sidecar pattern: <name>.sync-conflict-YYYYMMDD-HHMMSS-<DEVICE7>(.<ext>)?
_CONFLICT_RE = re.compile(
    r"^(?P<stem>.+)\.sync-conflict-\d{8}-\d{6}-[A-Z0-9]{7}(?P<ext>\.[^./]+)?$"
)


def scan_conflicts(data_dir: Path) -> list[dict]:
    out: list[dict] = []
    if not data_dir.exists():
        return out
    for p in data_dir.rglob("*.sync-conflict-*"):
        if not p.is_file():
            continue
        m = _CONFLICT_RE.match(p.name)
        if m:
            canonical_name = m.group("stem") + (m.group("ext") or "")
        else:
            canonical_name = p.name
        rel_dir = p.parent.relative_to(data_dir)
        canonical_rel = (
            str(rel_dir / canonical_name) if str(rel_dir) != "." else canonical_name
        )
        out.append({
            "sidecar": str(p.relative_to(data_dir)),
            "canonical": canonical_rel,
            "size": p.stat().st_size,
            "is_jsonl": canonical_name.endswith(".jsonl"),
            "exists": (p.parent / canonical_name).exists(),
        })
    return out


# ── Status gathering ──────────────────────────────────────────────────


def gather_status(cfg: dict) -> dict:
    data_dir = Path(cfg["DOTSYNC_DATA_DIR"])
    state_dir = Path(cfg["DOTSYNC_STATE_DIR"])
    home = Path.home()

    last_sync = ""
    last_sync_file = state_dir / "last-sync"
    if last_sync_file.exists():
        last_sync = last_sync_file.read_text().strip()

    paused = (state_dir / "sync-paused").exists()

    daemon = "unknown"
    try:
        out = subprocess.run(
            ["launchctl", "list"], capture_output=True, text=True, timeout=2
        ).stdout
        daemon = "loaded" if cfg["DOTSYNC_KC_SERVICE"] in out else "not-loaded"
    except Exception:
        pass

    syncthing = gather_syncthing(cfg)
    conflicts = scan_conflicts(data_dir)

    profiles: list[dict] = []
    enabled: set[str] = set()
    enabled_file = data_dir / "registry" / "enabled-profiles.json"
    if enabled_file.exists():
        try:
            enabled = set(
                json.loads(enabled_file.read_text()).get("profiles", []) or []
            )
        except Exception:
            pass
    profiles_dir = tool_dir() / "profiles"
    if profiles_dir.exists():
        for p in sorted(profiles_dir.glob("*.json")):
            try:
                d = json.loads(p.read_text())
                profiles.append({
                    "name": d.get("name", p.stem),
                    "description": d.get("description", ""),
                    "experimental": d.get("experimental", False),
                    "enabled": d.get("name") in enabled,
                    "paths": len(d.get("paths", [])),
                })
            except Exception:
                pass

    tracked: list[dict] = []
    secrets_file = data_dir / "registry" / "secrets.json"
    if secrets_file.exists():
        try:
            secrets = json.loads(secrets_file.read_text()).get("secrets", []) or []
            tracked = [
                {
                    "repo_path": s.get("repo_path", "?"),
                    "real_path": s.get("real_path", "?"),
                }
                for s in secrets
            ]
        except Exception:
            pass

    log_file = home / "Library" / "Logs" / "dotsync.log"
    log_tail: list[str] = []
    if log_file.exists():
        try:
            with log_file.open() as f:
                log_tail = [line.rstrip() for line in f.readlines()[-30:]]
        except Exception:
            pass

    # Overall health classification — single source of truth for the badge.
    if paused:
        health = "paused"
    elif conflicts:
        health = "conflicts"
    elif not syncthing.get("running"):
        health = "down"
    elif daemon != "loaded":
        health = "no-daemon"
    elif not any(p["connected"] for p in syncthing.get("peers", [])):
        health = "no-peers"
    else:
        health = "healthy"

    return {
        "version": VERSION,
        "service": cfg["DOTSYNC_KC_SERVICE"],
        "data_dir": str(data_dir),
        "state_dir": str(state_dir),
        "last_sync": last_sync,
        "paused": paused,
        "daemon": daemon,
        "health": health,
        "syncthing": syncthing,
        "conflicts": conflicts,
        "profiles": profiles,
        "tracked": tracked,
        "log_tail": log_tail,
        "now": dt.datetime.utcnow().isoformat() + "Z",
    }


