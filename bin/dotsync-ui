def html_escape(s: str) -> str:
    return (
        s.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
    )


def render_html(status: dict, version: str) -> str:
    # Status badge
    if status["paused"]:
        badge = '<span class="badge bad">paused</span>'
    elif status["conflicts"]:
        badge = '<span class="badge warn">conflicts</span>'
    elif status["daemon"] == "loaded":
        badge = '<span class="badge good">healthy</span>'
    else:
        badge = '<span class="badge warn">no daemon</span>'

    # Last sync — highlight if stale.
    last_sync_html = html_escape(status["last_sync"]) or "<em>never</em>"
    if status["last_sync"]:
        try:
            ts = dt.datetime.fromisoformat(status["last_sync"].replace("Z", "+00:00"))
            age_s = (dt.datetime.now(dt.timezone.utc) - ts).total_seconds()
            if age_s < 90:
                last_sync_html += f' <span class="pill">{int(age_s)}s ago</span>'
            elif age_s < 3600:
                last_sync_html += f' <span class="pill">{int(age_s/60)}m ago</span>'
            else:
                last_sync_html += f' <span class="pill">{int(age_s/3600)}h ago</span>'
        except Exception:
            pass

    # Pause/resume button
    if status["paused"]:
        pause_button = '<form action="/api/resume" method="post" style="display:inline;"><button type="submit">Resume</button></form>'
    else:
        pause_button = '<form action="/api/pause" method="post" style="display:inline;"><button type="submit">Pause</button></form>'

    # Peers
    if status["peers"]:
        rows = "".join(
            f"<tr><td>{html_escape(host)}</td><td>{html_escape(when)}</td></tr>"
            for host, when in status["peers"].items()
        )
        peers_html = f"<table><tr><th>Machine</th><th>Last commit</th></tr>{rows}</table>"
    else:
        peers_html = '<div class="empty">No peers seen yet.</div>'

    # Profiles
    if status["profiles"]:
        rows = []
        for p in status["profiles"]:
            mark = "✓" if p["enabled"] else "·"
            tag = ' <span class="pill">experimental</span>' if p["experimental"] else ""
            rows.append(
                f"<tr><td>{mark}</td><td><b>{html_escape(p['name'])}</b>{tag}</td>"
                f"<td>{html_escape(p['description'])}</td>"
                f"<td>{p['paths']} paths</td></tr>"
            )
        profiles_html = (
            "<table><tr><th></th><th>Profile</th><th>Description</th><th></th></tr>"
            + "".join(rows) + "</table>"
        )
    else:
        profiles_html = '<div class="empty">No profiles defined.</div>'

    # Syncthing engine panel (only when active)
    syncthing_panel = ""
    if status.get("engine") == "syncthing" and status.get("syncthing"):
        st = status["syncthing"]
        if not st.get("running"):
            syncthing_panel = (
                '<div class="panel"><h2>Syncthing</h2>'
                '<div class="empty">daemon not reachable. '
                'Check: <code>brew services list | grep syncthing</code></div></div>'
            )
        else:
            in_sync_pct = st.get("folder_in_sync_pct", 0)
            color = "good" if in_sync_pct > 99 else ("warn" if in_sync_pct > 80 else "bad")
            syncthing_panel = (
                f'<div class="panel"><h2>Syncthing</h2>'
                f'<table>'
                f'<tr><th>Version</th><td>{html_escape(st.get("version", "?"))}</td></tr>'
                f'<tr><th>This device</th><td><code>{html_escape(st.get("my_id", "?"))}</code></td></tr>'
                f'<tr><th>Folder</th><td>{html_escape(st.get("folder_id", "?"))}'
                f' <span class="badge {color}">{st.get("folder_state", "?")}</span></td></tr>'
                f'<tr><th>In sync</th><td>{in_sync_pct:.1f}% '
                f'({st.get("folder_local_files", 0)} local / '
                f'{st.get("folder_global_files", 0)} global files)</td></tr>'
                f'</table></div>'
            )

    # Conflicts panel
    if status["conflicts"]:
        rows = []
        for c in status["conflicts"]:
            rows.append(
                f"<tr><td>{html_escape(c['id'])}</td>"
                f"<td>{html_escape(', '.join(c['files']))}</td></tr>"
            )
        conflicts_panel = (
            '<div class="panel"><h2>Conflicts</h2>'
            "<table><tr><th>ID</th><th>Files</th></tr>"
            + "".join(rows)
            + "</table>"
            '<div style="margin-top:12px;color:var(--muted);">'
            "Run <code>dotsync resolve</code> in a terminal to resolve."
            "</div></div>"
        )
    else:
        conflicts_panel = ""

    # Projects
    projects_html = (
        "<ul>" + "".join(f"<li>{html_escape(p)}</li>" for p in status["projects"]) + "</ul>"
        if status["projects"] else '<div class="empty">No projects registered.</div>'
    )

    # Secrets
    secrets_html = (
        "<ul>"
        + "".join(
            f"<li><code>{html_escape(s.get('repo_path', '?'))}</code> ← <code>{html_escape(s.get('real_path', '?'))}</code></li>"
            for s in status["secrets"]
        )
        + "</ul>"
        if status["secrets"]
        else '<div class="empty">No secrets tracked. Use <code>dotsync track &lt;path&gt;</code>.</div>'
    )

    # Log
    log_html = html_escape("\n".join(status["log_tail"])) or "<em>(no log entries yet)</em>"

    return HTML_TEMPLATE.format(
        service=html_escape(status["service"]),
        data_dir=html_escape(status["data_dir"]),
        branch=html_escape(status["branch"]),
        status_badge=badge,
        last_sync_html=last_sync_html,
        daemon=html_escape(status["daemon"]),
        conflict_count=len(status["conflicts"]),
        now=html_escape(status["now"]),
        pause_button=pause_button,
        peers_html=peers_html,
        profiles_html=profiles_html,
        conflicts_panel=conflicts_panel,
        syncthing_panel=syncthing_panel,
        projects_html=projects_html,
        secrets_html=secrets_html,
        log_html=log_html,
        version=version,
    )


# ── HTTP handler ──────────────────────────────────────────────────────


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        # Quieter access log to stderr.
        sys.stderr.write(f"[{self.log_date_time_string()}] {format % args}\n")

    def _serve(self, code: int, body: bytes, content_type: str = "text/html; charset=utf-8"):
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        cfg = load_config()
        path = urllib.parse.urlparse(self.path).path
        if path == "/api/status":
            body = json.dumps(gather_status(cfg)).encode()
            self._serve(200, body, "application/json")
        elif path == "/" or path == "":
            status = gather_status(cfg)
            body = render_html(status, VERSION).encode()
            self._serve(200, body)
        else:
            self._serve(404, b"not found", "text/plain")

    def do_POST(self):
        path = urllib.parse.urlparse(self.path).path
        actions = {
            "/api/sync":   ["env-sync"],
            "/api/pause":  ["env-pause"],
            "/api/resume": ["dotsync-resume"],
        }
        cmd = actions.get(path)
        if not cmd:
            self._serve(404, b"not found", "text/plain")
            return
        bin_path = tool_dir() / "bin" / cmd[0]
        if not bin_path.exists():
            self._serve(501, f"{cmd[0]} not implemented yet".encode(), "text/plain")
            return
        # Run async and redirect.
        try:
            subprocess.Popen([str(bin_path)] + cmd[1:],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as e:
            self._serve(500, str(e).encode(), "text/plain")
            return
        self.send_response(303)
        self.send_header("Location", "/")
        self.end_headers()


# ── Entry ─────────────────────────────────────────────────────────────


VERSION = "0.3.0-dev"


def main():
    parser = argparse.ArgumentParser(description="dotsync local status dashboard")
    parser.add_argument("--port", type=int, default=7878)
    parser.add_argument("--bind", default="127.0.0.1")
    parser.add_argument("--no-open", action="store_true",
                        help="Don't open the browser automatically")
    parser.add_argument("--background", action="store_true",
                        help="Run silently (for launchd)")
    args = parser.parse_args()

    url = f"http://{args.bind}:{args.port}/"
    if not args.background:
        print(f"Dashboard at {url}")
        print("Reads existing state files; no new state written.")
        print("Ctrl-C to stop.")

    if not args.no_open and not args.background:
        try:
            webbrowser.open(url)
        except Exception:
            pass

    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer((args.bind, args.port), Handler) as httpd:
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            if not args.background:
                print("\nShutting down.")


if __name__ == "__main__":
    main()
