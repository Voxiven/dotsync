<script>
const $ = (id) => document.getElementById(id);

// Token capture + persistence: when arriving at /?token=X, save the token
// to localStorage and strip it from the URL (don't leave it in browser
// history or share links). All subsequent requests carry it as an
// X-Dotsync-Token header.
const TOKEN_KEY = "dotsync.token";
(function captureToken() {
  const url = new URL(location.href);
  const t = url.searchParams.get("token");
  if (t) {
    localStorage.setItem(TOKEN_KEY, t);
    url.searchParams.delete("token");
    history.replaceState(null, "", url.pathname + (url.search || "") + url.hash);
  }
})();
function authedFetch(path, opts) {
  opts = opts || {};
  const tok = localStorage.getItem(TOKEN_KEY);
  const headers = Object.assign({}, opts.headers || {});
  if (tok) headers["X-Dotsync-Token"] = tok;
  return fetch(path, Object.assign({}, opts, { headers, cache: "no-store" }));
}
function handleAuthFailure() {
  // Either we have no token, or it's wrong. Clear and bounce to login.
  localStorage.removeItem(TOKEN_KEY);
  location.href = "/?err=1";
}

function relTime(iso) {
  if (!iso) return null;
  const t = Date.parse(iso.replace(/Z$/, "Z"));
  if (isNaN(t)) return null;
  const sec = Math.max(0, Math.round((Date.now() - t) / 1000));
  if (sec < 60) return sec + "s ago";
  if (sec < 3600) return Math.round(sec/60) + "m ago";
  if (sec < 86400) return Math.round(sec/3600) + "h ago";
  return Math.round(sec/86400) + "d ago";
}

function fmtBytes(n) {
  if (!n) return "0 B";
  const u = ["B","KB","MB","GB","TB"];
  let i = 0;
  while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
  return n.toFixed(n >= 100 ? 0 : 1) + " " + u[i];
}

function escape(s) {
  return String(s ?? "").replace(/[&<>"]/g, c =>
    ({"&":"&amp;", "<":"&lt;", ">":"&gt;", '"':"&quot;"}[c]));
}

function renderHealth(health) {
  const el = $("health");
  const text = el.querySelector("[data-text]");
  const cls = {
    healthy: "good",
    "no-peers": "info",
    conflicts: "warn",
    paused: "bad",
    "no-daemon": "bad",
    down: "bad",
  }[health] || "info";
  el.className = "pill " + cls;
  text.textContent = ({
    healthy: "healthy",
    "no-peers": "no peers",
    conflicts: "conflicts",
    paused: "paused",
    "no-daemon": "no daemon",
    down: "syncthing down",
  }[health] || health);
}

function render(s) {
  renderHealth(s.health);
  $("ver").textContent = s.version;

  const stRunning = s.syncthing && s.syncthing.running;
  const folderState = stRunning ? s.syncthing.folder_state : "—";
  $("meta").innerHTML =
    escape(s.service) + " · " +
    escape(s.data_dir) + " " +
    '<span class="pill info" style="vertical-align:middle;">syncthing: ' +
    escape(folderState) + "</span>";

  // Last sync
  if (s.last_sync) {
    $("lastSync").textContent = relTime(s.last_sync) || s.last_sync;
    $("lastSyncSub").textContent = s.last_sync;
  } else if (stRunning) {
    $("lastSync").innerHTML = '<em>continuous</em>';
    $("lastSyncSub").textContent = "Syncthing replicates in real time";
  } else {
    $("lastSync").innerHTML = '<em>—</em>';
    $("lastSyncSub").textContent = "";
  }

  // Peers
  const peers = stRunning ? (s.syncthing.peers || []) : [];
  const conn = peers.filter(p => p.connected).length;
  $("peerCount").textContent = String(peers.length);
  $("peerSub").textContent = peers.length === 0 ? "no peers paired"
    : conn + " connected / " + (peers.length - conn) + " offline";

  // Peer table
  if (peers.length) {
    const kindLabel = {
      lan:     ["Direct LAN",  "good"],
      wan:     ["Direct WAN",  "good"],
      relay:   ["Relayed",     "info"],
      offline: ["Offline",     "bad"],
    };
    $("peerList").innerHTML =
      "<table><tr><th>Machine</th><th>Link</th><th>Address</th><th>Traffic</th></tr>" +
      peers.map(p => {
        const [label, cls] = kindLabel[p.connection_kind] || ["—", "bad"];
        return "<tr><td><code>" + escape(p.name) + "</code></td>" +
          "<td><span class='pill " + cls + "' title='" +
            (p.connection_kind === "relay"
              ? "Going through a Syncthing public relay (encrypted). Direct connect failed — likely a NAT or firewall."
              : p.connection_kind === "wan"
              ? "Direct peer-to-peer across networks (NAT-punched)."
              : p.connection_kind === "lan"
              ? "Direct peer-to-peer on the same local network."
              : "No active connection.") + "'>" +
            "<span class='dot'></span>" + label +
          "</span></td>" +
          "<td class='mono'>" + escape(p.address || "—") + "</td>" +
          "<td class='mono'>↑ " + fmtBytes(p.out_bytes) + " / ↓ " + fmtBytes(p.in_bytes) + "</td></tr>";
      }).join("") + "</table>";
  } else {
    $("peerList").innerHTML = stRunning
      ? '<div class="empty">No peers paired. Run <code>dotsync pair</code> to add one.</div>'
      : '<div class="empty">Syncthing daemon not reachable.</div>';
  }

  // Conflicts
  $("conflictCount").textContent = String(s.conflicts.length);
  $("conflictSub").textContent = s.conflicts.length === 0
    ? "all clear"
    : s.conflicts.filter(c => c.is_jsonl).length + " mergeable, " +
      s.conflicts.filter(c => !c.is_jsonl).length + " manual";
  if (s.conflicts.length) {
    $("conflictsCard").hidden = false;
    $("conflictList").innerHTML = s.conflicts.map(c =>
      "<div class='conflict-row'>" +
        "<div>" +
          "<div class='file'>" + escape(c.canonical) + "</div>" +
          "<div class='meta-line'>" +
            (c.is_jsonl ? '<span class="pill info" style="margin-right:6px;">jsonl</span>' :
                          '<span class="pill warn" style="margin-right:6px;">manual</span>') +
            fmtBytes(c.size) + " · sidecar: " + escape(c.sidecar) +
          "</div>" +
        "</div>" +
      "</div>"
    ).join("");
  } else {
    $("conflictsCard").hidden = true;
  }

  // Profiles
  if (s.profiles.length) {
    $("profileList").innerHTML =
      "<table>" +
      s.profiles.map(p =>
        "<tr><td style='width:24px;color:" + (p.enabled ? "var(--good)" : "var(--muted)") + ";'>" +
          (p.enabled ? "✓" : "·") + "</td>" +
        "<td><b>" + escape(p.name) + "</b>" +
          (p.experimental ? ' <span class="pill info">experimental</span>' : "") +
        "</td>" +
        "<td>" + escape(p.description) + "</td>" +
        "<td style='color:var(--muted);text-align:right;'>" + p.paths + " paths</td></tr>"
      ).join("") + "</table>";
  } else {
    $("profileList").innerHTML = '<div class="empty">No profiles defined.</div>';
  }

  // Tracked
  if (s.tracked && s.tracked.length) {
    $("trackedCard").hidden = false;
    $("trackedList").innerHTML =
      "<table><tr><th>Repo path</th><th>Real path</th></tr>" +
      s.tracked.map(t =>
        "<tr><td><code>" + escape(t.repo_path) + "</code></td>" +
        "<td><code>" + escape(t.real_path) + "</code></td></tr>"
      ).join("") + "</table>";
  } else {
    $("trackedCard").hidden = true;
  }

  // Pause/resume button
  const pauseBtn = $("actPause");
  pauseBtn.textContent = s.paused ? "Resume" : "Pause";
  pauseBtn.dataset.action = s.paused ? "resume" : "pause";

  // Resolve button only enabled when there are conflicts
  $("actClean").disabled = !s.conflicts.length;

  // Syncthing details
  if (stRunning) {
    const st = s.syncthing;
    $("stDetail").innerHTML =
      "<table>" +
      "<tr><th>Version</th><td>" + escape(st.version || "—") + "</td></tr>" +
      "<tr><th>This device</th><td><code>" + escape(st.my_id || "—") + "</code></td></tr>" +
      "<tr><th>Folder</th><td><code>" + escape(st.folder_id) + "</code> · " +
        escape(st.folder_state) + "</td></tr>" +
      "<tr><th>In sync</th><td>" + st.in_sync_pct.toFixed(1) + "% · " +
        st.local_files + " local / " + st.global_files + " global files</td></tr>" +
      "<tr><th>Daemon</th><td>" + escape(s.daemon) + "</td></tr>" +
      "</table>";
  } else {
    $("stDetail").innerHTML =
      '<div class="empty">Syncthing not reachable. Start it with: ' +
      '<code>brew services start syncthing</code></div>';
  }

  // Log
  $("logTail").textContent = s.log_tail.length
    ? s.log_tail.join("\n")
    : "(no log entries yet)";
}

let toastTimer;
function toast(msg, isError) {
  const t = $("toast");
  t.textContent = msg;
  t.className = "toast show" + (isError ? " error" : "");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { t.className = "toast"; }, 4000);
}

async function refresh() {
  try {
    const r = await authedFetch("/api/status");
    if (r.status === 401) return handleAuthFailure();
    if (!r.ok) throw new Error("HTTP " + r.status);
    const s = await r.json();
    render(s);
  } catch (e) {
    toast("Failed to load status: " + e.message, true);
  }
}

async function action(path, btn) {
  if (btn) btn.disabled = true;
  try {
    const r = await authedFetch(path, { method: "POST" });
    if (r.status === 401) return handleAuthFailure();
    const body = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(body.error || ("HTTP " + r.status));
    if (body.message) toast(body.message);
    await refresh();
  } catch (e) {
    toast("Action failed: " + e.message, true);
  } finally {
    if (btn) btn.disabled = false;
  }
}

$("actSync").addEventListener("click", e => action("/api/sync", e.currentTarget));
$("actPause").addEventListener("click", e =>
  action("/api/" + e.currentTarget.dataset.action, e.currentTarget));
$("actClean").addEventListener("click", e => action("/api/clean-conflicts", e.currentTarget));
$("actMergeAll").addEventListener("click", e => action("/api/clean-conflicts", e.currentTarget));
$("actSyncthing").addEventListener("click", () =>
  window.open("http://127.0.0.1:8384/", "_blank"));
$("refreshNow").addEventListener("click", e => { e.preventDefault(); refresh(); });

refresh();
setInterval(refresh, 5000);
</script>
</body>
</html>
"""


