#!/usr/bin/env bash
# One-shot bootstrap. Reads ~/.config/dotsync/config.sh; clones data repo;
# seeds Keychain (if needed); symlinks Claude memory + dotfiles; installs
# the launchd daemon; runs an initial sync.
#
# Runnable directly OR via:
#   curl -fsSL https://raw.githubusercontent.com/Voxiven/dotsync/main/bin/env-bootstrap | bash
set -uo pipefail

step() { printf '\n→ %s\n' "$*"; }
fail() { printf '✗ %s\n' "$*" >&2; exit 1; }

step "dotsync bootstrap on $(hostname -s)"

# 1. Verify dependencies
[[ "$(uname -s)" == "Darwin" ]] || fail "macOS only (Linux support tracked in #issues)"
command -v git  >/dev/null || fail "git required"
command -v brew >/dev/null || fail "Homebrew required (https://brew.sh/)"

require_or_install() {
  if ! command -v "$1" >/dev/null 2>&1; then
    step "Installing $1"
    brew install "$1" || fail "brew install $1 failed"
  fi
}
require_or_install git-crypt
require_or_install age
require_or_install jq
require_or_install fswatch

# 2. Resolve TOOL_DIR (where these scripts live).
TOOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# When run via `curl | bash`, BASH_SOURCE[0] is empty; in that case we'll have
# to clone the tool repo ourselves. Detect and recover.
if [[ ! -d "$TOOL_DIR/bin" ]]; then
  TOOL_DIR="${HOME}/.dotsync-tool"
  if [[ ! -d "$TOOL_DIR/.git" ]]; then
    step "Cloning dotsync tool → $TOOL_DIR"
    git clone https://github.com/Voxiven/dotsync.git "$TOOL_DIR" --quiet \
      || fail "clone of dotsync tool repo failed"
  fi
fi

# 3. Resolve config. Prompt to create if missing.
DOTSYNC_CONFIG="${DOTSYNC_CONFIG:-${HOME}/.config/dotsync/config.sh}"
mkdir -p "$(dirname "$DOTSYNC_CONFIG")"

if [[ ! -f "$DOTSYNC_CONFIG" ]]; then
  step "No config at $DOTSYNC_CONFIG — running interactive setup"
  echo
  echo "dotsync needs a private git remote where it stores your encrypted data."
  echo "Create one (e.g. on GitHub) and paste its HTTPS URL below."
  read -rp "Data repo URL (e.g. https://github.com/yourname/dotsync-data.git): " REMOTE_URL
  [[ -n "$REMOTE_URL" ]] || fail "data repo URL required"
  read -rp "Local checkout path [\$HOME/.dotsync-data]: " DATA_DIR
  DATA_DIR="${DATA_DIR:-${HOME}/.dotsync-data}"
  cat > "$DOTSYNC_CONFIG" <<CONFIG
# dotsync config — generated by env-bootstrap on $(date -u +%Y-%m-%dT%H:%M:%SZ)
DOTSYNC_DATA_DIR="$DATA_DIR"
DOTSYNC_DATA_REMOTE="$REMOTE_URL"
DOTSYNC_KC_SERVICE="dev.dotsync.envsync"
DOTSYNC_KC_ACCOUNT="default"
CONFIG
  step "Wrote $DOTSYNC_CONFIG"
fi

# shellcheck source=/dev/null
source "$DOTSYNC_CONFIG"
DOTSYNC_DATA_DIR="${DOTSYNC_DATA_DIR:?DOTSYNC_DATA_DIR not set in $DOTSYNC_CONFIG}"
DOTSYNC_DATA_REMOTE="${DOTSYNC_DATA_REMOTE:?DOTSYNC_DATA_REMOTE not set in $DOTSYNC_CONFIG}"
DOTSYNC_DATA_BRANCH="${DOTSYNC_DATA_BRANCH:-main}"
DOTSYNC_KC_SERVICE="${DOTSYNC_KC_SERVICE:-dev.dotsync.envsync}"
DOTSYNC_KC_ACCOUNT="${DOTSYNC_KC_ACCOUNT:-default}"

BACKUP_DIR="${HOME}/.dotsync-backup-$(date -u +%Y%m%dT%H%M%SZ)"

# 4. Clone or update the data repo. Always operate on $DOTSYNC_DATA_BRANCH —
# the data branch may be an orphan (no shared history with the remote's
# default branch), so we must never fall back to whatever HEAD points at.
if [[ -d "$DOTSYNC_DATA_DIR/.git" ]]; then
  step "Data repo exists at $DOTSYNC_DATA_DIR — fetching latest $DOTSYNC_DATA_BRANCH"
  git -C "$DOTSYNC_DATA_DIR" fetch origin "$DOTSYNC_DATA_BRANCH" --quiet \
    || fail "fetch of $DOTSYNC_DATA_BRANCH failed"
  git -C "$DOTSYNC_DATA_DIR" checkout "$DOTSYNC_DATA_BRANCH" --quiet 2>/dev/null \
    || fail "could not check out $DOTSYNC_DATA_BRANCH"
  git -C "$DOTSYNC_DATA_DIR" merge --ff-only "origin/$DOTSYNC_DATA_BRANCH" --quiet 2>/dev/null \
    || step "(local has unpushed commits; leaving them alone)"
else
  step "Cloning $DOTSYNC_DATA_REMOTE ($DOTSYNC_DATA_BRANCH) → $DOTSYNC_DATA_DIR"
  git clone -b "$DOTSYNC_DATA_BRANCH" "$DOTSYNC_DATA_REMOTE" "$DOTSYNC_DATA_DIR" --quiet \
    || fail "clone of data repo failed (branch: $DOTSYNC_DATA_BRANCH)"
fi

# 5. Source helpers (now that DOTSYNC_DATA_DIR exists and tool dir is known).
# shellcheck source=/dev/null
source "$TOOL_DIR/bin/_common.sh"
# shellcheck source=/dev/null
source "$TOOL_DIR/bin/_crypt.sh"
# shellcheck source=/dev/null
source "$TOOL_DIR/bin/_registry.sh"

# 6. Verify Keychain has the age identity.
if ! kc_has_identity; then
  echo
  echo "No age identity in Keychain (service=$DOTSYNC_KC_SERVICE account=$DOTSYNC_KC_ACCOUNT)."
  echo
  echo "  • First Mac:   See README — generate the identity with age-keygen,"
  echo "                 encrypt the git-crypt key to it, store the identity"
  echo "                 in Keychain, save a copy in 1Password."
  echo "  • Second Mac:  On your first Mac, retrieve the identity:"
  echo "                   security find-generic-password -s '$DOTSYNC_KC_SERVICE' -a '$DOTSYNC_KC_ACCOUNT' -w"
  echo "                 Then on this Mac, paste it into Keychain:"
  echo "                   security add-generic-password -s '$DOTSYNC_KC_SERVICE' -a '$DOTSYNC_KC_ACCOUNT' -U -w"
  echo "                 Re-run env-bootstrap when done."
  exit 1
fi

# 7. Unlock the data repo (idempotent).
unlock_repo

# 8. Back up any preexisting Claude artifacts before symlinking.
mkdir -p "$BACKUP_DIR"
backup_if_exists() {
  local p="$1"
  [[ -e "$p" && ! -L "$p" ]] || return 0
  local rel="${p#$HOME/}"
  mkdir -p "$(dirname "$BACKUP_DIR/$rel")"
  mv "$p" "$BACKUP_DIR/$rel" || fail "could not back up $p"
  log_info "backed up $p → $BACKUP_DIR/$rel"
}
mkdir -p "$HOME/.claude"

# 9. Symlink memory + dotfiles into the data repo.
SHARED_MEMORY="$DOTSYNC_DATA_DIR/claude/memory"
mkdir -p "$SHARED_MEMORY"
while read -r proj; do
  dst_memory="$HOME/.claude/projects/$proj/memory"
  mkdir -p "$(dirname "$dst_memory")"
  backup_if_exists "$dst_memory"
  ln -sfn "$SHARED_MEMORY" "$dst_memory"
  log_info "symlinked $dst_memory → $SHARED_MEMORY"
done < <(project_names)

mkdir -p "$DOTSYNC_DATA_DIR/dotfiles"
# Dotfiles are sync'd via capture/deploy (cp), not symlinks. Symlinking puts
# the data repo's working tree directly under the path Claude Code writes
# to (e.g. ~/.claude/settings.json), which races env-sync's rebase: a write
# between the autostash and the internal checkout makes rebase abort with
# "Your local changes to ... would be overwritten by checkout."
while IFS=$'\t' read -r repo_p real_p; do
  repo_full="$DOTSYNC_DATA_DIR/$repo_p"
  mkdir -p "$(dirname "$repo_full")"

  # Migrate legacy symlink → real file. Snapshot the symlink target's
  # current content (live process may have written to it), drop the link,
  # restore as a regular file.
  if [[ -L "$real_p" ]]; then
    target="$(readlink "$real_p")"
    if [[ "$target" == "$repo_full" ]]; then
      log_info "migrating symlink → copy: $real_p"
      tmp="$(mktemp)"
      cp "$real_p" "$tmp" 2>/dev/null || true   # snapshot via the symlink
      rm "$real_p"
      [[ -s "$tmp" ]] && mv "$tmp" "$real_p" || rm -f "$tmp"
    fi
  fi

  # Seed direction:
  #   - real exists, repo missing/empty → seed repo from real (first machine)
  #   - repo exists, real missing       → deploy repo to real (joining machine)
  #   - both exist                       → leave alone; sync will reconcile
  if [[ -f "$real_p" && ! -L "$real_p" ]]; then
    if [[ ! -s "$repo_full" ]]; then
      cp "$real_p" "$repo_full"
      log_info "seeded $repo_p from $real_p"
    fi
  elif [[ -f "$repo_full" ]]; then
    mkdir -p "$(dirname "$real_p")"
    cp "$repo_full" "$real_p"
    log_info "deployed $repo_p → $real_p"
  else
    # Neither side has content; create empty placeholders so capture/deploy
    # don't skip on subsequent runs.
    touch "$repo_full"
  fi
done < <(dotfile_pairs)

# 10. First-machine seeding: if data dir is still empty, copy from backup.
seed_from_backup() {
  local src="$1" dst="$2" desc="$3"
  if [[ -d "$src" && -z "$(find "$dst" -mindepth 1 -not -name '.gitkeep' 2>/dev/null | head -1)" ]]; then
    step "Seeding $desc from backup"
    cp -R "$src"/* "$dst/" 2>/dev/null || true
  fi
}
for backup_memory in "$BACKUP_DIR"/.claude/projects/*/memory; do
  [[ -d "$backup_memory" && -n "$(ls -A "$backup_memory" 2>/dev/null)" ]] || continue
  seed_from_backup "$backup_memory" "$SHARED_MEMORY" "memory"
  break
done
# Dotfile seeding is handled inline by the dotfile_pairs loop in step 9
# (since v0.3 — dotfiles are no longer symlinked).

# 11. Capture tracked .env files.
step "Capturing tracked .env files"
while IFS=$'\t' read -r repo_p real_p; do
  if [[ -f "$real_p" && ! -f "$DOTSYNC_DATA_DIR/$repo_p" ]]; then
    mkdir -p "$(dirname "$DOTSYNC_DATA_DIR/$repo_p")"
    cp "$real_p" "$DOTSYNC_DATA_DIR/$repo_p"
    log_info "seeded $repo_p from $real_p"
  fi
done < <(secrets_pairs)

# 12. Render + install launchd plist.
step "Installing launchd agent"
LABEL="$DOTSYNC_KC_SERVICE"   # match Keychain service for discoverability
plist_dest="$HOME/Library/LaunchAgents/${LABEL}.plist"
mkdir -p "$(dirname "$plist_dest")"
sed \
  -e "s|__LABEL__|$LABEL|g" \
  -e "s|__TOOL_DIR__|$TOOL_DIR|g" \
  -e "s|__DATA_DIR__|$DOTSYNC_DATA_DIR|g" \
  -e "s|__HOME__|$HOME|g" \
  -e "s|__CONFIG__|$DOTSYNC_CONFIG|g" \
  "$TOOL_DIR/launchd/dev.dotsync.envsync.plist.template" > "$plist_dest"
plutil -lint "$plist_dest" >/dev/null || fail "plist invalid"
launchctl unload "$plist_dest" 2>/dev/null || true
launchctl load -w "$plist_dest" || fail "launchctl load failed"
log_info "launchd agent loaded ($plist_dest)"

# 13. Initial sync.
step "Running initial sync"
if "$TOOL_DIR/bin/env-sync"; then
  log_info "initial sync OK"
else
  log_warn "initial sync had issues; check $ENV_LOG_FILE"
fi

# 14. Cleanup empty backup dir.
if [[ -d "$BACKUP_DIR" && -z "$(find "$BACKUP_DIR" -type f 2>/dev/null | head -1)" ]]; then
  rmdir "$BACKUP_DIR" 2>/dev/null || true
  BACKUP_DIR="(empty, removed)"
fi

cat <<EOF

✅ dotsync bootstrap complete.
   Tool:    $TOOL_DIR
   Data:    $DOTSYNC_DATA_DIR
   Config:  $DOTSYNC_CONFIG
   Backup:  $BACKUP_DIR
   Daemon:  loaded ($plist_dest)
   Status:  $TOOL_DIR/bin/env-status

Edit memory normally — changes auto-sync within 60 seconds.

EOF
