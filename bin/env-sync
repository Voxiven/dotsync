#!/usr/bin/env bash
# env-sync — periodic capture/deploy cycle. Driven by the launchd agent
# every 60s by default. Idempotent: most paths are symlinked into the
# Syncthing folder and do nothing here; non-symlink paths (sessions,
# ad-hoc tracked secrets) get rsync'd in/out via the profile engine.
#
# Sync engine: Syncthing (the only engine in v0.4+). The Syncthing daemon
# replicates the data dir to peers; this script bridges between CC's
# canonical paths and that folder for paths that aren't symlink-able.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_common.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_registry.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_profile.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/_syncthing.sh"

# Capture/deploy ad-hoc tracked items (the secrets registry — used by
# 'dotsync track' and the project-secrets profile's user additions).
capture_secrets() {
  local repo_p real_p
  while IFS=$'\t' read -r repo_p real_p; do
    [[ -f "$real_p" ]] || continue
    mkdir -p "$(dirname "$ENV_REPO_ROOT/$repo_p")"
    rsync -a --checksum "$real_p" "$ENV_REPO_ROOT/$repo_p"
  done < <(secrets_pairs)
}

deploy_secrets() {
  local repo_p real_p
  while IFS=$'\t' read -r repo_p real_p; do
    [[ -f "$ENV_REPO_ROOT/$repo_p" ]] || continue
    mkdir -p "$(dirname "$real_p")"
    rsync -a --checksum "$ENV_REPO_ROOT/$repo_p" "$real_p"
  done < <(secrets_pairs)
}

# Safety net for the rare cross-peer divergence on a session file that
# went idle on both peers and got merged into different shapes — the
# session-jsonls capture is now idle-gated (0.6.0+), so most active
# divergences never produce sidecars in the first place. When sidecars
# DO appear (e.g. settings.json edited on both peers, or a session that
# closed on one peer and was reopened on the other), the JSONL ones
# line-union merge losslessly and non-JSONL ones are left for human
# review. Quiet when there's nothing to do.
auto_merge_conflicts() {
  local first_sidecar
  first_sidecar=$(find "$ENV_REPO_ROOT" -name '*.sync-conflict-*' -type f 2>/dev/null | head -1)
  [[ -z "$first_sidecar" ]] && return 0
  log_info "auto-merging sync-conflict files"
  "$SCRIPT_DIR/dotsync-clean-conflicts" --apply --merge 2>&1 \
    | grep -E '^(Cleaned|Manual review|  )' \
    | while IFS= read -r line; do
        log_info "  $line"
      done || true
}

# Prune session storage in the repo: drop oversize files, drop subagents/
# subtrees (per-machine state we don't sync), drop skipped projects.
# Idempotent.
prune_sessions() {
  local max_mb="${DOTSYNC_SESSION_MAX_MB:-50}"
  local skip="${DOTSYNC_SKIP_PROJECTS:-}"
  if [[ -d "$ENV_REPO_ROOT/sessions" ]]; then
    find "$ENV_REPO_ROOT/sessions" -name '*.jsonl' -size "+${max_mb}M" -delete 2>/dev/null || true
    find "$ENV_REPO_ROOT/sessions" -type d -name 'subagents' -exec rm -rf {} + 2>/dev/null || true
    local name encoded
    while IFS=$'\t' read -r name encoded; do
      if [[ " $skip " == *" $name "* || " $skip " == *" $encoded "* ]]; then
        rm -rf "$ENV_REPO_ROOT/sessions/$name" 2>/dev/null || true
        [[ "$name" != "$encoded" ]] && rm -rf "$ENV_REPO_ROOT/sessions/$encoded" 2>/dev/null || true
      fi
    done < <(project_pairs)
  fi
}

# ── main ─────────────────────────────────────────────────────────────

# Per-machine mutex (mkdir lock; flock isn't on default macOS).
# $ENV_LOCK_DIR is in $DOTSYNC_STATE_DIR (per-machine), set in _common.sh.
if ! mkdir "$ENV_LOCK_DIR" 2>/dev/null; then
  log_info "another env-sync is running; exiting cleanly"
  exit 0
fi
trap 'rmdir "$ENV_LOCK_DIR" 2>/dev/null' EXIT

if is_paused; then
  log_warn "sync paused; run 'dotsync resume' to re-enable"
  exit 0
fi

cd "$ENV_REPO_ROOT" || die "cannot cd to $ENV_REPO_ROOT (run 'dotsync init' first?)"

if ! st_running; then
  log_warn "Syncthing daemon not reachable at $SYNCTHING_API_BASE; skipping cycle"
  exit 0
fi

# 0. Self-heal .stignore. Per-machine file (Syncthing doesn't replicate
#    it), so a peer joined before this rule existed — or a peer where
#    it got deleted — can quietly miss the sidecar exclusion and start
#    re-pulling phantom conflict files from its index every drain. The
#    helper is content-aware, so this is free on the happy path; logs
#    only when it actually heals something.
st_write_stignore

# 1. Capture local-machine state into the data dir. Syncthing replicates
#    async. Symlinked profile paths are no-ops here (already in-place);
#    only non-symlink paths (sessions, project-secrets) do real work.
capture_secrets
if profile_mode_active; then
  log_info "profile mode: $(enabled_profiles | tr '\n' ' ')"
  profile_run_all capture
fi
prune_sessions

# 2. Nudge Syncthing to scan now (skip the next watch interval).
st_rescan >/dev/null 2>&1 || true

# 3. Wait briefly for inbound replication to settle so deploy reads the
#    post-replication state. Best-effort; deploy works on whatever's
#    there if the wait times out.
st_wait_idle "$SYNCTHING_FOLDER_ID" 10 >/dev/null 2>&1 || true

# 4. Deploy peer state to canonical paths. Same caveat as capture:
#    symlinked paths are no-ops; only non-symlink paths do real work.
deploy_secrets
if profile_mode_active; then
  profile_run_all deploy
fi

# 5. Auto-merge conflicts AFTER deploy: by now Syncthing has dropped any
#    sidecars it's going to drop this cycle, so we can sweep them in one
#    pass. Removing a sidecar + writing the merged canonical also nudges
#    Syncthing to replicate that to peers, propagating the merge.
auto_merge_conflicts

date -u +%Y-%m-%dT%H:%M:%SZ > "$ENV_LASTSYNC_FILE"
log_info "sync complete"
